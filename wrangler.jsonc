{
	"name": "letni-skola-ai",
	"compatibility_date": "2026-04-15",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},

	// D1 Database
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "letni-skola-ai-db",
			"database_id": "placeholder-update-after-d1-create"
		}
	],

	// R2 Storage (certificates, lesson images)
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "letni-skola-ai-storage"
		}
	],

	// Environment variables
	"vars": {
		"APP_URL": "https://skola.aivefirmach.cz",
		"MAIL_FROM": "Letní škola AI <patrick@skola.aivefirmach.cz>"
	},

	// Cron triggers
	"triggers": {
		"crons": [
			"0 5,6,7 * * 1-5",
			"*/30 * * * *",
			"0 7 * * *",
			"0 16 * * *"
		]
	}

	// Secrets (configure via `wrangler secret put`):
	// RESEND_API_KEY
	// ANTHROPIC_API_KEY
	// FIO_API_TOKEN
	// ADMIN_EMAIL
	// JWT_SECRET
	// CRON_SECRET
}
