---
import PublicLayout from '@layouts/PublicLayout.astro';
import { getOne, getAll } from '@lib/db';
import { renderMarkdown } from '@lib/markdown';
import type { Enrollment, Course, Lesson, Certificate } from '@lib/types';

const { id } = Astro.params;
const user = Astro.locals.user!;
const env = Astro.locals.runtime.env;

const enrollment = await getOne<Enrollment>(
  env.DB,
  `SELECT * FROM enrollments WHERE id = ? AND user_id = ?`,
  id,
  user.id,
);

if (!enrollment) {
  return Astro.redirect('/profil');
}

const course = await getOne<Course>(
  env.DB,
  `SELECT * FROM courses WHERE id = ?`,
  enrollment.course_id,
);

if (!course) {
  return Astro.redirect('/profil');
}

const lessons = await getAll<Lesson>(
  env.DB,
  `SELECT * FROM lessons WHERE course_id = ? ORDER BY position ASC`,
  course.id,
);

const certificate = await getOne<Certificate>(
  env.DB,
  `SELECT * FROM certificates WHERE enrollment_id = ?`,
  enrollment.id,
);

const statusLabels: Record<string, string> = {
  pending: 'Čeká na aktivaci',
  active: 'Aktivní',
  paused: 'Pozastaveno',
  stalled: 'Neaktivní',
  completed: 'Dokončeno',
  cancelled: 'Zrušeno',
};
---

<PublicLayout title={course.title}>
  <div class="mx-auto max-w-3xl py-8">
    <a href="/profil" class="text-sm text-gray-500 hover:text-gray-700">&larr; Zpět na profil</a>

    <header class="mt-4">
      <h1 class="text-2xl font-bold text-gray-900">{course.title}</h1>
      <div class="mt-2 flex items-center gap-3">
        <span class="rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-700">
          {statusLabels[enrollment.status] || enrollment.status}
        </span>
        <span class="text-sm text-gray-500">
          Lekce {Math.min(enrollment.current_lesson, course.lesson_count)} z {course.lesson_count}
        </span>
      </div>
    </header>

    {enrollment.status === 'completed' && (
      <div class="mt-6 rounded-lg bg-green-50 p-4">
        <p class="font-medium text-green-800">Kurz byl dokončen!</p>
        <div class="mt-2 flex gap-3">
          {!certificate && enrollment.score === null && (
            <a href={`/test/${enrollment.id}`} class="rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700">
              Složit závěrečný test
            </a>
          )}
          {certificate && (
            <a href={`/certifikat/${certificate.public_id}`} class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
              Zobrazit certifikát
            </a>
          )}
        </div>
      </div>
    )}

    <section class="mt-8">
      <h2 class="text-lg font-semibold text-gray-900">Lekce</h2>
      <ol class="mt-4 space-y-2">
        {lessons.map((lesson) => {
          const isCompleted = lesson.position < enrollment.current_lesson;
          const isCurrent = lesson.position === enrollment.current_lesson;
          return (
            <li class:list={[
              'flex items-center gap-3 rounded-lg border px-4 py-3',
              isCompleted ? 'border-green-200 bg-green-50' : isCurrent ? 'border-blue-200 bg-blue-50' : 'border-gray-100',
            ]}>
              <span class:list={[
                'flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-medium',
                isCompleted ? 'bg-green-200 text-green-700' : isCurrent ? 'bg-blue-200 text-blue-700' : 'bg-gray-100 text-gray-500',
              ]}>
                {isCompleted ? '\u2713' : lesson.position}
              </span>
              <span class:list={['text-gray-900', isCompleted && 'line-through opacity-60']}>
                {lesson.title}
              </span>
              <span class="ml-auto text-xs text-gray-400">{lesson.reading_minutes} min</span>
            </li>
          );
        })}
      </ol>
    </section>

    {enrollment.status === 'active' && course.delivery_mode === 'on_click' && (
      <div class="mt-6 text-center">
        <button
          id="mark-done"
          class="rounded-lg bg-blue-600 px-6 py-2 font-medium text-white hover:bg-blue-700"
          data-enrollment-id={enrollment.id}
        >
          Pokračovat na další lekci
        </button>
      </div>
      <script>
        document.getElementById('mark-done')?.addEventListener('click', async (e) => {
          const btn = e.target as HTMLButtonElement;
          const id = btn.dataset.enrollmentId;
          btn.disabled = true;
          btn.textContent = 'Odesílám...';
          const res = await fetch(`/api/enrollments/${id}/done`, { method: 'POST' });
          if (res.ok) {
            window.location.reload();
          } else {
            btn.disabled = false;
            btn.textContent = 'Pokračovat na další lekci';
            alert('Nastala chyba.');
          }
        });
      </script>
    )}
  </div>
</PublicLayout>
