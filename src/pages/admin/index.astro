---
import AdminLayout from '@layouts/AdminLayout.astro';
import { getAll, getOne } from '@lib/db';

const env = Astro.locals.runtime.env;

interface Stats {
  total_enrollments: number;
  active_enrollments: number;
  completed_enrollments: number;
  total_revenue: number;
  pending_orders: number;
  unmatched_payments: number;
}

const [
  enrollmentStats,
  revenueRow,
  pendingOrders,
  unmatchedPayments,
  recentOrders,
] = await Promise.all([
  getAll<{ status: string; count: number }>(
    env.DB,
    `SELECT status, COUNT(*) as count FROM enrollments GROUP BY status`,
  ),
  getOne<{ total: number }>(
    env.DB,
    `SELECT COALESCE(SUM(amount_czk), 0) as total FROM orders WHERE status = 'paid'`,
  ),
  getOne<{ count: number }>(
    env.DB,
    `SELECT COUNT(*) as count FROM orders WHERE status = 'pending'`,
  ),
  getOne<{ count: number }>(
    env.DB,
    `SELECT COUNT(*) as count FROM payments WHERE matched_order_id IS NULL`,
  ),
  getAll<{ id: string; user_email: string; course_title: string; amount_czk: number; status: string; created_at: string }>(
    env.DB,
    `SELECT o.id, u.email as user_email, c.title as course_title,
            o.amount_czk, o.status, o.created_at
     FROM orders o
     JOIN users u ON o.user_id = u.id
     JOIN courses c ON o.course_id = c.id
     ORDER BY o.created_at DESC LIMIT 5`,
  ),
]);

const byStatus = Object.fromEntries(enrollmentStats.map((r) => [r.status, r.count]));
const totalEnrollments = enrollmentStats.reduce((s, r) => s + r.count, 0);

const statusColors: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-700',
  paid: 'bg-green-100 text-green-700',
  cancelled: 'bg-red-100 text-red-700',
  overpaid: 'bg-orange-100 text-orange-700',
  underpaid: 'bg-orange-100 text-orange-700',
};
---

<AdminLayout title="Dashboard">
  {(unmatchedPayments?.count ?? 0) > 0 && (
    <div class="mb-6 rounded-lg bg-orange-50 border border-orange-200 px-4 py-3 text-sm text-orange-800">
      ⚠️ <strong>{unmatchedPayments?.count} nespárovaných plateb</strong> čeká na ruční zpracování.
      <a href="/admin/platby" class="ml-2 underline hover:no-underline">Zobrazit platby →</a>
    </div>
  )}

  <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl border border-gray-200 bg-white p-5">
      <p class="text-sm text-gray-500">Celkem enrollmentů</p>
      <p class="mt-1 text-3xl font-bold text-gray-900">{totalEnrollments}</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5">
      <p class="text-sm text-gray-500">Aktivní</p>
      <p class="mt-1 text-3xl font-bold text-blue-600">{byStatus['active'] ?? 0}</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5">
      <p class="text-sm text-gray-500">Dokončené</p>
      <p class="mt-1 text-3xl font-bold text-green-600">{byStatus['completed'] ?? 0}</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5">
      <p class="text-sm text-gray-500">Tržby celkem</p>
      <p class="mt-1 text-3xl font-bold text-gray-900">{(revenueRow?.total ?? 0).toLocaleString('cs-CZ')} Kč</p>
    </div>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <section>
      <h2 class="mb-3 text-lg font-semibold text-gray-900">Enrollmenty dle stavu</h2>
      <div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
        {[
          ['pending', 'Čeká na aktivaci'],
          ['active', 'Aktivní'],
          ['paused', 'Pozastaveno'],
          ['stalled', 'Neaktivní'],
          ['completed', 'Dokončeno'],
          ['cancelled', 'Zrušeno'],
        ].map(([status, label]) => (
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-sm text-gray-700">{label}</span>
            <span class="text-sm font-semibold text-gray-900">{byStatus[status] ?? 0}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold text-gray-900">Poslední objednávky</h2>
        <a href="/admin/objednavky" class="text-sm text-blue-600 hover:underline">Zobrazit vše</a>
      </div>
      <div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
        {recentOrders.length === 0 ? (
          <p class="px-4 py-6 text-sm text-gray-500">Žádné objednávky.</p>
        ) : recentOrders.map((o) => (
          <div class="px-4 py-3">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-gray-900 truncate max-w-[200px]">{o.user_email}</span>
              <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium', statusColors[o.status] ?? 'bg-gray-100 text-gray-700']}>
                {o.status}
              </span>
            </div>
            <p class="text-xs text-gray-500 mt-0.5">{o.course_title} · {o.amount_czk} Kč</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</AdminLayout>
