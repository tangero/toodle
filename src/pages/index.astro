---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="Kurzy" description="Naučte se AI krok za krokem — drip email kurzy pro začátečníky i firmy.">
  <section class="py-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Letní škola AI</h1>
    <p class="mt-4 text-lg text-gray-600">
      Naučte se AI krok za krokem. Každý den jedna krátká lekce do emailu.
    </p>
  </section>

  <section class="py-8">
    <h2 class="mb-6 text-2xl font-bold text-gray-900">Dostupné kurzy</h2>
    <p class="text-gray-500">Kurzy se brzy objeví.</p>
  </section>
</PublicLayout>
