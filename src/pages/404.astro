---
import PublicLayout from '@layouts/PublicLayout.astro';
---

<PublicLayout title="Stránka nenalezena">
  <div class="py-24 text-center">
    <p class="text-6xl font-bold text-gray-200">404</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900">Stránka nenalezena</h1>
    <p class="mt-2 text-gray-600">Tato stránka neexistuje nebo byla přesunuta.</p>
    <a href="/" class="mt-6 inline-block rounded-lg bg-blue-600 px-6 py-2 text-sm font-medium text-white hover:bg-blue-700">
      Zpět na hlavní stránku
    </a>
  </div>
</PublicLayout>
