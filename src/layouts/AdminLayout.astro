---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/kurzy', label: 'Kurzy' },
  { href: '/admin/uzivatele', label: 'Uživatelé' },
  { href: '/admin/objednavky', label: 'Objednávky' },
  { href: '/admin/platby', label: 'Platby' },
  { href: '/admin/nastaveni', label: 'Nastavení' },
];
---

<BaseLayout title={`Admin: ${title}`}>
  <div class="flex min-h-screen">
    <aside class="w-56 border-r border-gray-200 bg-gray-50">
      <div class="p-4">
        <a href="/admin" class="text-lg font-bold text-gray-900">Admin</a>
      </div>
      <nav class="mt-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block px-4 py-2 text-sm',
              currentPath === item.href
                ? 'bg-blue-50 font-medium text-blue-700'
                : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="mt-auto border-t border-gray-200 p-4">
        <a href="/" class="text-sm text-gray-500 hover:text-gray-700">&larr; Zpět na web</a>
      </div>
    </aside>

    <main class="flex-1 p-8">
      <h1 class="mb-6 text-2xl font-bold text-gray-900">{title}</h1>
      <slot />
    </main>
  </div>
</BaseLayout>
